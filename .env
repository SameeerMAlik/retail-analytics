# ─────────────────────────────────────────────────────────────────────────────
# Enterprise Retail Analytics Engine — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Snowflake Connection ──────────────────────────────────────────────────────
# Account identifier format: <org_name>-<account_name>  OR  <account>.<region>
SF_ACCOUNT=your_account.us-east-1
SF_USER=your_snowflake_username
SF_PASSWORD=your_snowflake_password
SF_WAREHOUSE=COMPUTE_WH
SF_DATABASE=RETAIL_ANALYTICS_DB
SF_SCHEMA=ANALYTICS
SF_ROLE=SYSADMIN

# ── Google Gemini AI API ──────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AQ.Ab8RN6Lfq6CRLDNzVQ8Wvdd1SxCMvGqHotzbJpuNkP71lF9eqQ

# ── Flask Application ─────────────────────────────────────────────────────────
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=abc123
FLASK_DEBUG=True
FLASK_PORT=5000

# ── Cache Settings ────────────────────────────────────────────────────────────
# How long (seconds) to cache Snowflake query results in memory
CACHE_TTL=300

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# Set to True to force demo mode even when Snowflake creds are present.
# Useful for UI development without warehouse costs.
DEMO_MODE=False

# ─────────────────────────────────────────────────────────────────────────────
# NOTES:
#   - If SF_ACCOUNT / SF_USER / SF_PASSWORD are missing, app auto-switches to
#     demo mode and serves synthetic data — no Snowflake needed.
#   - If GEMINI_API_KEY is missing, the AI SQL page uses pattern-matched demo
#     responses instead of calling the Gemini API.
# ─────────────────────────────────────────────────────────────────────────────
